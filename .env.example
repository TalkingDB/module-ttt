# =============================================================================
# TalkingDB environment configuration
# Copy this file to `.env` and update values as needed.
# =============================================================================


# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# Bearer token used by all API endpoints.
# Leave empty to disable auth in local development.
TDB_API_KEY=


# -----------------------------------------------------------------------------
# Upload limits
# -----------------------------------------------------------------------------

# Maximum upload size in MB.
# default: 50
TDB_MAX_FILE_SIZE_MB=50


# -----------------------------------------------------------------------------
# SQLite storage
# -----------------------------------------------------------------------------

# SQLite database path.
# default: data/graphs.db
GRAPH_DB=data/graphs.db

# SQLite busy timeout in milliseconds.
# default: 5000
TDB_SQLITE_BUSY_TIMEOUT_MS=5000


# -----------------------------------------------------------------------------
# Content elementizer
# -----------------------------------------------------------------------------

# DIRECT = local parsing
# API    = remote CE service
# default: DIRECT
CLIENT_MODE=DIRECT

# Used only when CLIENT_MODE=API
CE_HOST=


# -----------------------------------------------------------------------------
# Async jobs - concurrency
# -----------------------------------------------------------------------------

# Worker pool size.
# default: min(4, cpu_count())
TDB_JOB_MAX_WORKERS=4

# Queue capacity before returning HTTP 429.
# default: 2 * TDB_JOB_MAX_WORKERS
TDB_JOB_QUEUE_CAPACITY=8

# Retry-After value for queue saturation.
# default: 30
TDB_JOB_RETRY_AFTER_SECONDS=30


# -----------------------------------------------------------------------------
# Async jobs - progress
# -----------------------------------------------------------------------------

# Progress checkpoint interval.
# default: 25
TDB_JOB_CHECKPOINT_BATCH=25

# Minimum heartbeat gap in seconds.
# default: 2
TDB_JOB_HEARTBEAT_MIN_GAP_SECONDS=2


# -----------------------------------------------------------------------------
# Async jobs - timeout handling
# -----------------------------------------------------------------------------

# Heartbeat stale threshold in seconds.
# default: 300  (5 minutes)
TDB_JOB_STALE_THRESHOLD_SECONDS=300

# Maximum job runtime in seconds.
# default: 1800  (30 minutes)
TDB_JOB_MAX_DURATION_SECONDS=1800


# -----------------------------------------------------------------------------
# Async jobs - retention
# -----------------------------------------------------------------------------

# Completed-job retention.
# default: 2592000 (30 days)
TDB_RETENTION_COMPLETED_SECONDS=2592000

# Failed-job retention.
# default: 604800 (7 days)
TDB_RETENTION_FAILED_SECONDS=604800

# Cancelled-job retention.
# default: 86400 (1 day)
TDB_RETENTION_CANCELLED_SECONDS=86400

# Daemon sweep interval in seconds.
# default: 60
TDB_JOB_DAEMON_INTERVAL_SECONDS=60


# -----------------------------------------------------------------------------
# Async jobs - spool storage
# -----------------------------------------------------------------------------

# Upload spool directory.
# default: /var/tmp/tdb-spool
TDB_SPOOL_DIR=/var/tmp/tdb-spool

# Minimum free spool space in MB before rejecting uploads.
# default: 512
TDB_MIN_FREE_SPOOL_MB=512

# Upload chunk size in bytes.
# default: 1048576 (1 MiB)
TDB_SPOOL_CHUNK_BYTES=1048576

# Retry-After value for spool exhaustion.
# default: 30
TDB_RETRY_AFTER_SECONDS=30
